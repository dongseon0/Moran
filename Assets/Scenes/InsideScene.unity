  m_Script: {fileID: 11500000, guid: 4264dda553731e949acb5b736f3db9f8, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::LoveLetterInteractable
  ghostWarningUI: {fileID: 0}
  promptEWithText: {fileID: 0}
  narrationPanel: {fileID: 1935115962}
  narrationText: {fileID: 2062544056}
  endingImageUI: {fileID: 0}
  sentences:
  - "\uBAA8\uB780\uC5D0\uAC8C"
  - "\uC804\uAC01 \uB4A4\uB730\uC758 \uAF43\uC774 \uBA70\uCE60 \uC0C8 \uB9CE\uC774
    \uC2DC\uB4E4\uC5C8\uC2B5\uB2C8\uB2E4. \n\uB0A0\uC774 \uAE09\uD788 \uCD94\uC6CC\uC9C4
    \uD0D3\uC77C\uAE4C\uC694?"
  - "\uBD80\uB514 \uBAB8\uC870\uC2EC\uD558\uC168\uC73C\uBA74 \uD569\uB2C8\uB2E4"
  - "\uC694\uC988\uC74C \uAD81 \uC548\uC758 \uB9D0\uB4E4\uC774 \uC2EC\uC0C1\uCE58
    \uC54A\uC2B5\uB2C8\uB2E4. \n\uBD80\uB514 \uC774\uC804\uCC98\uB7FC \uC790\uC8FC
    \uC774\uACF3\uC744 \uCC3E\uC9C0\uB294 \uB9C8\uC2ED\uC2DC\uC624."
  - "\uADF8\uB9AC\uACE0 \uADF8\uB0A0 \uBE4C\uB824\uAC00\uC2E0 \uBE44\uB140\uB294
    \uB3CC\uB824\uC8FC\uC2DC\uC9C0 \uC54A\uC544\uB3C4 \uB429\uB2C8\uB2E4. \n\uC560\uCD08\uC5D0
    \uADF8 \uBB3C\uAC74\uC740 \uC81C\uAC8C \uC5B4\uC6B8\uB9AC\uC9C0 \uC54A\uC558\uC73C\uB2C8\uAE4C\uC694."
  - ...............
  - "\"\uBAA8\uB780...\""
  - "\uB0A1\uC740 \uC5F0\uC11C \uC18D \uC774\uB984\uC744 \uBCF4\uB294 \uC21C\uAC04,
    \uC78A\uACE0 \uC788\uB358 \uAE30\uC5B5\uC774 \uB9C8\uCE68\uB0B4 \uB418\uC0B4\uC544\uB0AC\uB2E4.
    \n\uB098\uB294 \uC655\uC758 \uD6C4\uAD81\uC774\uC5C8\uB2E4.\n\uB204\uAD6C\uBCF4\uB2E4
    \uCD1D\uC560\uBC1B\uC558\uACE0, \uB204\uAD6C\uBCF4\uB2E4 \uC644\uBCBD\uD574\uC57C
    \uD588\uB2E4."
  - "\uADF8\uB7EC\uB098 \uB05D\uB0B4 \uADF8\uB140\uB97C \uD5A5\uD55C \uB9C8\uC74C\uB9CC\uD07C\uC740
    \uC228\uAE30\uC9C0 \uBABB\uD588\uB2E4. \n\uB204\uAD70\uAC00 \uB0B4\uAC00 \uC655\uC774
    \uC544\uB2CC \uB2E4\uB978 \uC774\uC640 \uC815\uC744 \uD1B5\uD588\uB2E4\uACE0
    \uB9D0\uD588\uACE0, \uB098\uB294 \uC8FD\uC5C8\uB2E4."
  - "\uD558\uC9C0\uB9CC \uBAA8\uB780\uC740 \uC0B4\uC544\uC788\uB2E4. \n\uB0B4\uAC00
    \uB05D\uAE4C\uC9C0 \uC9C0\uCF1C\uB0B8 \uB2E8 \uD558\uB098\uC758 \uC0AC\uB78C.\n\uADF8
    \uC544\uC774\uB294 \uC544\uC9C1 \uC774 \uAD81 \uC5B4\uB518\uAC00\uC5D0\uC11C
    \uC544\uBB34\uAC83\uB3C4 \uBAA8\uB978 \uCC99 \uC228\uC744 \uC8FD\uC778 \uCC44
    \uC0B4\uC544\uAC00\uACE0 \uC788\uACA0\uC9C0.\r\n"
  - "\uADF8\uB7EC\uB2C8 \uB098\uB294 \uBC18\uB4DC\uC2DC \uC54C\uC544\uB0B4\uC57C
    \uD55C\uB2E4."
  - "\uB204\uAC00 \uC6B0\uB9AC\uB97C \uBC00\uACE0\uD588\uB294\uC9C0, \uB204\uAC00
    \uB098\uB97C \uC8FD\uC74C\uC73C\uB85C \uBAB0\uC544\uB123\uC5C8\uB294\uC9C0, \n\uADF8\uB9AC\uACE0..
    \uBAA8\uB780\uC774 \uC544\uC9C1 \uBB34\uC0AC\uD55C\uC9C0. "
  - "\uC774 \uAD81\uC774 \uC228\uAE30\uACE0 \uC788\uB294 \uBE44\uBC00\uC744 \uD480\uC5B4\uB0B4
    \uBC18\uB4DC\uC2DC \uBAA8\uB780\uC744 \uC9C0\uCF1C\uC57C \uD55C\uB2E4."
  onNarrationEnd:
