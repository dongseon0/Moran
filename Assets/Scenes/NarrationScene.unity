      value: "\uADF8\uB807\uC9C0\uB9CC... \uB531 \uD55C \uAC00\uC9C0\uB9CC\uC774
        \uAE30\uC5B5\uB09C\uB2E4. \n[\uBAA8\uB780]\n\uADF8 \uB2E8\uC5B4\uB294 \uC5B4\uB290\uC0C8
        \uBA38\uB9BF\uC18D\uC744 \uAC00\uB4DD \uCC44\uC6E0\uB2E4."
      objectReference: {fileID: 0}
    - target: {fileID: 4199914899064487305, guid: 1a68de76935148c498cf509e95b05ca6, type: 3}
      propertyPath: 'sentences.Array.data[5]'
      value: "\uBC14\uB2E5\uC5D0\uC11C \uC720\uC11C\uAC00 \uB5A8\uC5B4\uC838\uC788\uB2E4."
      objectReference: {fileID: 0}
    - target: {fileID: 4199914899064487305, guid: 1a68de76935148c498cf509e95b05ca6, type: 3}
      propertyPath: 'sentences.Array.data[6]'
      value: "\u201C\u2026\uC0AC\uB791\uD558\uB358 \uBAA8\uB780\uC774 \uC9C0\uB358
        \uB0A0, \uC138\uC0C1\uB3C4 \uD568\uAED8 \uBB34\uB108\uC84C\uB2E4. \n\uBD89\uAC8C
        \uBB3C\uB4E0 \uADF8 \uD6C4\uAD81\uC804\uC758 \uB730\uC5D0 \uB0B4 \uB9C8\uC9C0\uB9C9
        \uC228\uC744 \uBB3B\uB294\uB2E4. \n\uBAA8\uB780\uC774 \uB2E4\uC2DC \uD750\uB4DC\uB7EC\uC9C0\uAC8C
        \uD53C\uC5B4\uB0A0 \uB54C, \uB2F9\uC2E0\uC740 \uB098\uB97C \uAE30\uC5B5\uD560\uAE4C?\u201D"
      objectReference: {fileID: 0}
    - target: {fileID: 4199914899064487305, guid: 1a68de76935148c498cf509e95b05ca6, type: 3}
      propertyPath: 'sentences.Array.data[7]'
      value: "\uB204\uAD70\uAC00\uC758 \uC808\uB9DD\uC774 \uB2F4\uAE34 \uC720\uC11C.\r\n\uC820\uC7A5,
        \uB610 \uBAA8\uB780\uC774\uB2E4. ...\uBAA8\uB780, \uBAA8\uB780!"
      objectReference: {fileID: 0}
    - target: {fileID: 4199914899064487305, guid: 1a68de76935148c498cf509e95b05ca6, type: 3}
      propertyPath: 'sentences.Array.data[8]'
      value: "\uBA38\uB9BF\uC18D\uC758 \uC794\uC0C1\uC774 \uAC70\uC138\uAC8C \uC694\uB3D9\uCE5C\uB2E4.
        \n\uADF8\uB798, \uBAA8\uB780\uC774 \uAC00\uB4DD \uD53C\uC5C8\uB2E4\uB294
        \uD6C4\uAD81\uC804\uC5D0 \uC5B4\uB514 \uD55C \uBC88 \uAC00\uBCF4\uC790\uACE0. "
      objectReference: {fileID: 0}
    - target: {fileID: 4199914899064487305, guid: 1a68de76935148c498cf509e95b05ca6, type: 3}
      propertyPath: 'sentences.Array.data[9]'
      value: "\uBAA8\uB780\uC774 \uAC00\uB4DD \uD53C\uC5B4\uC788\uB294 '\uD6C4\uAD81\uC804'\uC73C\uB85C
        \uAC00\uC57C\uB9CC \uD560 \uAC83 \uAC19\uB2E4. "
      objectReference: {fileID: 0}
    - target: {fileID: 4199914899064487305, guid: 1a68de76935148c498cf509e95b05ca6, type: 3}
      propertyPath: 'sentences.Array.data[10]'
      value: "\uADF8\uACF3\uC5D0\uC11C \uAE30\uC5B5\uC774\uB4E0 \uBAA8\uB780\uC774\uB4E0
        \uBB50\uB4E0\uAC04\uC5D0 \uC54C\uC544\uB0B4\uACA0\uC5B4."
      objectReference: {fileID: 0}
