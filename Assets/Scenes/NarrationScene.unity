    - target: {fileID: 4199914899064487305, guid: 1a68de76935148c498cf509e95b05ca6, type: 3}
      propertyPath: 'sentences.Array.data[3]'
      value: "\uAE30\uC5B5\uB098\uB294 \uAC83\uC740 \uC544\uBB34\uAC83\uB3C4 \uC5C6\uB2E4.\n\uB0B4\uAC00
